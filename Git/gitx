generate_ai_commit() {
  ensure_git_repo

  # 1. Check for staged changes
  if git diff --cached --quiet; then
    echo -e "${RED}No staged changes found.${NC}"
    echo "Please stage your changes first using 'git add <files>'."
    exit 1
  fi

  # 2. Check for dependencies
  if ! command -v jq &> /dev/null; then
    echo -e "${RED}Error: 'jq' is required for JSON processing.${NC}"
    echo "Please install it (e.g., sudo apt install jq)."
    exit 1
  fi

  # 3. Handle Credentials & Model (Env Vars override config)
  if [[ -z "$GEMINI_API_KEY" || -z "$GEMINI_MODEL" ]]; then
    load_or_prompt_gemini_config
  fi

  echo "Analyzing staged changes..."

  # Generate base64 encoded diff (cross-platform clean)
  local diff_b64
  diff_b64=$(git diff --cached | base64 | tr -d '\n' || true)

  if [[ -z "$diff_b64" ]]; then
    echo -e "${RED}Error: Failed to read or encode git diff.${NC}"
    exit 1
  fi

  # 4. Load & Decode the System Instruction
  # It prioritizes: 1. Environment Var 2. Saved File 3. Hardcoded string
  local sys_instruction_b64="${GITX_SYS_INSTRUCTION_B64:-}"

  if [[ -z "$sys_instruction_b64" && -f "$GITX_INSTRUCTION_FILE" ]]; then
    sys_instruction_b64=$(cat "$GITX_INSTRUCTION_FILE")
  fi

  if [[ -z "$sys_instruction_b64" ]]; then
    sys_instruction_b64=""
  fi

  local sys_instruction
  sys_instruction=$(echo -n "$sys_instruction_b64" | base64 --decode)

  if [[ -z "$sys_instruction" ]]; then
    echo -e "${RED}Error: Failed to decode system instructions.${NC}"
    exit 1
  fi

  local payload_file="/tmp/gitx_payload_$$.json"

  # 5. Build JSON Payload
  jq -n \
    --arg sys "$sys_instruction" \
    --arg diff_b64 "$diff_b64" \
    '{
      "system_instruction": {
        "parts": [{ "text": $sys }]
      },
      "contents": [{
        "parts": [
          { "text": "Analyze the following git diff and generate a commit message:" },
          {
            "inline_data": {
              "mime_type": "text/plain",
              "data": $diff_b64
            }
          }
        ]
      }],
      "generation_config": {
        "temperature": 0.1,
        "topP": 0.9,
        "topK": 1
      }
    }' > "$payload_file"

  # 6. Call the Gemini API
  echo "Generating commit message via Gemini ($GEMINI_MODEL)..."
  local api_url="https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=$GEMINI_API_KEY"

  local response
  response=$(curl -s -X POST "$api_url" \
    -H 'Content-Type: application/json' \
    -d @"$payload_file")

  # 7. Extract message
  local commit_msg
  commit_msg=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text // empty')

  # Cleanup temp files
  rm -f "$payload_file"

  if [[ -z "$commit_msg" || "$commit_msg" == "null" ]]; then
    echo -e "${RED}Error generating commit message. API Response:${NC}"
    echo "$response" | jq .
    exit 1
  fi

  # 8. Present output to user
  echo -e "\n${YELLOW}================ Generated Commit Message ================${NC}\n"
  echo "$commit_msg"
  echo -e "\n${YELLOW}==========================================================${NC}\n"

  read -rp "Do you want to commit with this message? (y/e/n) [y=yes, e=edit, n=no]: " action
  case "$action" in
  y|Y)
    git commit -m "$commit_msg"
    echo -e "${GREEN}Committed successfully.${NC}"
    ;;
  e|E)
    local msg_file="/tmp/gitx_commit_msg_$$.txt"
    echo "$commit_msg" > "$msg_file"
    ${EDITOR:-vi} "$msg_file"
    git commit -F "$msg_file"
    rm -f "$msg_file"
    echo -e "${GREEN}Committed successfully.${NC}"
    ;;
  *)
    echo "Commit cancelled. Your changes remain staged."
    ;;
  esac
}

# Hooks initializer
hooks_manager() {
  ensure_git_repo
  local sub="${1:-}"

  if [[ "$sub" != "init" ]]; then
    echo "Usage: gitx hooks init"
    return 1
  fi

  local root hooks_dir
  root=$(git rev-parse --show-toplevel)
  hooks_dir="$root/.git/hooks"
  mkdir -p "$hooks_dir"

  cat >"$hooks_dir/prepare-commit-msg.gitx" <<'EOF'
#!/bin/sh
# gitx prepare-commit-msg hook example
# Appends Conventional Commit template as comments.

MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Skip merges, rebases, etc.
case "$COMMIT_SOURCE" in
  merge|squash|commit|message) ;;
  *) exit 0 ;;
esac

if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

if grep -q "Conventional Commit format" "$MSG_FILE"; then
  exit 0
fi

cat <<'TEMPLATE' >>"$MSG_FILE"

# Conventional Commit format: <type>(scope?): <subject>
# Types: feat, fix, chore, docs, refactor, test, perf, build, ci, style, revert
# Example: feat(auth): add login with OTP
# Optional: use gitmoji: :sparkles: feat: add new feature

TEMPLATE
EOF

  cat >"$hooks_dir/pre-commit.gitx" <<'EOF'
#!/bin/sh
# gitx pre-commit hook example
# Fails commit if conflict markers are present.

if git diff --cached | grep -q '<<<<<<< HEAD'; then
  echo "Error: Conflict markers detected in staged changes."
  echo "Please resolve conflicts before committing."
  exit 1
fi

exit 0
EOF

  cat >"$hooks_dir/pre-push.gitx" <<'EOF'
#!/bin/sh
# gitx pre-push hook example
# Runs tests if a common test runner is found.

if [ -f "vendor/bin/pest" ]; then
  echo "Running Pest tests..."
  vendor/bin/pest || exit 1
elif [ -f "vendor/bin/phpunit" ]; then
  echo "Running PHPUnit tests..."
  vendor/bin/phpunit || exit 1
fi

exit 0
EOF

  chmod +x "$hooks_dir/"*.gitx

  echo "Hook templates installed:"
  echo "  - $hooks_dir/prepare-commit-msg.gitx"
  echo "  - $hooks_dir/pre-commit.gitx"
  echo "  - $hooks_dir/pre-push.gitx"

  read -rp "Activate these hooks now (copy without .gitx)? (y/n): " yn
  if [[ "$yn" == "y" ]]; then
    cp "$hooks_dir/prepare-commit-msg.gitx" "$hooks_dir/prepare-commit-msg"
    cp "$hooks_dir/pre-commit.gitx" "$hooks_dir/pre-commit"
    cp "$hooks_dir/pre-push.gitx" "$hooks_dir/pre-push"
    chmod +x "$hooks_dir/prepare-commit-msg" "$hooks_dir/pre-commit" "$hooks_dir/pre-push"
    echo "Hooks activated."
  else
    echo "You can manually enable them by copying *.gitx to hook names in .git/hooks."
  fi
}

trap "echo -e '${RED}Process interrupted. Exiting.${NC}'; exit 6" SIGINT SIGTERM

