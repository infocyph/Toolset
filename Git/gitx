    function esc_csv(s,  r) {
      gsub(/"/, "\"\"", s)
      return "\"" s "\""
    }
    /^>>/ {
      line = substr($0, 3)
      n = split(line, parts, "|")
      commit_id   = parts[1]
      email       = parts[2]
      ts          = parts[3]
      subject     = parts[4]
      body        = (n >= 5 ? parts[5] : "")
